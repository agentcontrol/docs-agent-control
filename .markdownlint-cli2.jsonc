{
  // markdownlint-cli2 configuration file
  // Uses the existing .markdownlint.jsonc rules
  // and excludes generated/auto-generated content
  
  "config": ".markdownlint.jsonc",
  
  "ignores": [
    // Exclude node_modules and other common directories
    "node_modules/**",
    ".git/**",
    ".github/**",
    
    // Exclude package lock files
    "package-lock.json"
  ],
  
  "customRules": [],
  
  "outputFormatters": [
    ["markdownlint-cli2-formatter-default"]
  ]
}
